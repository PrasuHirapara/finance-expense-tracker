<mxfile host="app.diagrams.net" modified="2026-04-03T23:20:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="credential-schema" name="Credential Database Schema">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Credential Storage Schema" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="360" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="secure" value="Secure Storage&#xa;credential.encryption_key.value&#xa;credential.biometric_unlock.enabled&#xa;&#xa;Purpose&#xa;- stores encryption key&#xa;- stores biometric toggle&#xa;&#xa;Notes&#xa;- OS-backed secure storage&#xa;- not stored in SQLite" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="260" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="sqlite" value="Local SQLite: DbCredentials&#xa;id : int PK&#xa;title : text&#xa;encryptedPayload : text&#xa;saltBase64 : text&#xa;nonceBase64 : text&#xa;createdAt : datetime&#xa;updatedAt : datetime&#xa;&#xa;Security state&#xa;- title plaintext locally&#xa;- fields encrypted locally" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="350" y="90" width="300" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="payloadjson" value="Decrypted field JSON before encryption&#xa;[&#xa;  {key, value},&#xa;  {key, value}&#xa;]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="720" y="110" width="240" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="cloudmanifest" value="Firestore&#xa;/users/{uid}/cloud_sync/manifest&#xa;&#xa;Contains&#xa;- schemaVersion&#xa;- exportedAt&#xa;- localLatestAt&#xa;- accountEmail&#xa;- domainCounts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1010" y="80" width="270" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="cloudcredential" value="Firestore&#xa;/users/{uid}/cloud_sync/credential&#xa;&#xa;Contains when credential sync ON&#xa;- encryptedPayload&#xa;- saltBase64&#xa;- nonceBase64&#xa;- titleEncryptedPayload&#xa;- titleSaltBase64&#xa;- titleNonceBase64&#xa;- timestamps&#xa;&#xa;Deleted when credential sync OFF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="1010" y="280" width="320" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="stores key" style="endArrow=block;html=1;rounded=0;strokeColor=#6c8ebf" edge="1" parent="1" source="secure" target="sqlite">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="encrypt / decrypt fields" style="endArrow=block;html=1;rounded=0;strokeColor=#d6b656" edge="1" parent="1" source="payloadjson" target="sqlite">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="build cloud backup" style="endArrow=block;html=1;rounded=0;strokeColor=#b85450" edge="1" parent="1" source="sqlite" target="cloudcredential">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="backup metadata" style="endArrow=block;html=1;rounded=0;strokeColor=#b85450" edge="1" parent="1" source="sqlite" target="cloudmanifest">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="Security interpretation&#xa;- local secure fields are encrypted&#xa;- local title is visible for search/list&#xa;- cloud title is encrypted before upload&#xa;- Firestore rules restrict access by uid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="350" y="390" width="420" height="150" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
